{
  "name": "finametrics",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "concurrently --names \"API,VITE\" -c \"yellow,cyan\" \"tsx api/server.ts\" \"vite\"",
    "dev:api": "tsx api/server.ts",
    "dev:vite": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,css,html,json}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css,html,json}\""
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "lucide-react": "^1.21.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.30.4",
    "recharts": "^2.12.7",
    "xlsx": "^0.18.5",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^8.60.0",
    "@typescript-eslint/parser": "^8.60.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.2.3",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "postcss": "^8.4.41",
    "prettier": "^3.8.3",
    "tailwindcss": "^3.4.10",
    "tsx": "^4.22.4",
    "typescript": "^5.5.3",
    "vite": "^7.0.0"
  }
}
